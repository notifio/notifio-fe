{
  "name": "@notifio/mobile",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start --dev-client",
    "build:ios": "eas build --platform ios",
    "build:android": "eas build --platform android",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "clean": "rm -rf .expo",
    "eas-build-pre-install": "cd ../.. && echo \"@notifio:registry=https://npm.pkg.github.com\" > .npmrc && echo \"//npm.pkg.github.com/:_authToken=${SHARED_PACKAGES_TOKEN}\" >> .npmrc"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-native-firebase/app": "^24.0.0",
    "@react-native-firebase/messaging": "^24.0.0",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@supabase/supabase-js": "^2.101.1",
    "@tabler/icons-react-native": "^3.41.1",
    "aes-js": "^3.1.2",
    "expo": "~55.0.5",
    "expo-build-properties": "~55.0.11",
    "expo-constants": "~55.0.7",
    "expo-linear-gradient": "~55.0.8",
    "expo-linking": "~55.0.7",
    "expo-localization": "^55.0.13",
    "expo-location": "~55.1.7",
    "expo-notifications": "~55.0.16",
    "expo-router": "~55.0.4",
    "expo-secure-store": "~55.0.9",
    "expo-splash-screen": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "i18next": "^26.0.5",
    "react": "19.2.0",
    "react-i18next": "^17.0.4",
    "react-native": "0.83.2",
    "react-native-get-random-values": "~1.11.0",
    "react-native-map-clustering": "^4.0.0",
    "react-native-maps": "1.26.20",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-toast-message": "^2.3.3",
    "react-native-url-polyfill": "^3.0.0"
  },
  "devDependencies": {
    "@types/aes-js": "^3.1.4",
    "@types/react": "~19.2.2",
    "typescript": "~5.9.2"
  }
}
